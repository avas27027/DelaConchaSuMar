DOCKERHUB_USERNAME=tu-usuario
IMAGE_TAG=latest

FRONTEND_PORT=3000
BACKEND_PORT=3001

# URL publica que usara el navegador para hablar con el backend.
# Ejemplos:
# PUBLIC_BACKEND_URL=https://api.tudominio.com
# PUBLIC_BACKEND_URL=http://localhost:3001
PUBLIC_BACKEND_URL=http://localhost:3001

# Origen permitido por CORS para el frontend.
# Ejemplos:
# CORS_ORIGIN=https://tudominio.com
# CORS_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

FIREBASE_PROJECT_ID=de-la-concha-su-mar
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@de-la-concha-su-mar.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_STORAGE_BUCKET=
