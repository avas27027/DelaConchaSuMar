        </svg>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    height: var(--spacing-header);
    background-color: var(--color-bg);
    padding: 0 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #bec8cd17;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .brand-title h1 {
    font-size: 24px;
    font-weight: 800;
    color: var(--color-deep-cyan);
    letter-spacing: -1.2px;
  }

  .search-container {
    flex-grow: 1;
    max-width: 600px;
    padding: 0 48px;
  }

  .search-input-wrapper {
    position: relative;
    width: 100%;
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background-color: var(--color-sidebar);
    border: 1px solid transparent;
    border-radius: 9999px;
    padding: 9px 16px 9px 48px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-text-primary);
    outline: none;
    transition: all 0.2s ease;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input:focus {
    border-color: var(--color-brand-cyan);
    background-color: var(--color-white);
    box-shadow: 0 0 0 4px rgba(0, 119, 145, 0.1);
  }

  .user-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .notification-btn {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    border: 1px solid #bec8cd4d;
    background: transparent;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    position: relative;
    transition: all 0.2s ease;
  }

  .notification-btn:hover {
    background-color: #0077911a;
  }

  .notification-dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 8px;
    height: 8px;
    background-color: var(--color-accent-orange);
    border-radius: 9999px;
    border: 1.5px solid var(--color-bg);
  }

  .profile-section {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-left: 16px;
    border-left: 1px solid #bec8cd17;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .user-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .user-role {
    font-size: 10px;
    font-weight: 700;
    color: var(--color-text-secondary);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .profile-avatar {
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
