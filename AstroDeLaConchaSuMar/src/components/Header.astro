---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="header">
  <div class="brand-title">
    <h1>{title}</h1>
  </div>

  <div class="user-actions">
    <div class="profile-section">
      <div class="profile-info">
        <span class="user-name">alvaro_10_12@hotmail.com</span>
        <span class="user-role">ADMIN</span>
      </div>
      <div class="profile-avatar">
        <svg
          width="25"
          height="25"
          viewBox="0 0 25 25"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M4.8125 18.875c1.0625-0.8125 2.25-1.45313 3.5625-1.92188 1.3125-0.46875 2.6875-0.70313 4.125-0.70312 1.4375 0 2.8125 0.23438 4.125 0.70313 1.3125 0.46875 2.5 1.10938 3.5625 1.92187 0.72917-0.85417 1.29688-1.82292 1.70313-2.90625 0.40625-1.08333 0.60938-2.23958 0.60937-3.46875 0-2.77083-0.97396-5.13021-2.92188-7.07813-1.94792-1.94792-4.30729-2.92188-7.07812-2.92187-2.77083 0-5.13021 0.97396-7.07813 2.92188-1.94792 1.94792-2.92188 4.30729-2.92187 7.07812 0 1.22917 0.20313 2.38542 0.60938 3.46875 0.40625 1.08333 0.97396 2.05208 1.70312 2.90625l0 0m7.6875-5.125c-1.22917 0-2.26563-0.42188-3.10938-1.26563-0.84375-0.84375-1.26563-1.88021-1.26562-3.10937 0-1.22917 0.42188-2.26563 1.26562-3.10938 0.84375-0.84375 1.88021-1.26563 3.10938-1.26562 1.22917 0 2.26563 0.42188 3.10938 1.26562 0.84375 0.84375 1.26563 1.88021 1.26562 3.10938 0 1.22917-0.42188 2.26563-1.26562 3.10938-0.84375 0.84375-1.88021 1.26563-3.10938 1.26562l0 0m0 11.25c-1.72917 0-3.35417-0.32813-4.875-0.98438-1.52083-0.65625-2.84375-1.54688-3.96875-2.67187-1.125-1.125-2.01563-2.44792-2.67188-3.96875-0.65625-1.52083-0.98438-3.14583-0.98437-4.875 0-1.72917 0.32813-3.35417 0.98437-4.875 0.65625-1.52083 1.54688-2.84375 2.67188-3.96875 1.125-1.125 2.44792-2.01563 3.96875-2.67188 1.52083-0.65625 3.14583-0.98438 4.875-0.98437 1.72917 0 3.35417 0.32813 4.875 0.98437 1.52083 0.65625 2.84375 1.54688 3.96875 2.67188 1.125 1.125 2.01563 2.44792 2.67188 3.96875 0.65625 1.52083 0.98438 3.14583 0.98437 4.875 0 1.72917-0.32813 3.35417-0.98437 4.875-0.65625 1.52083-1.54688 2.84375-2.67188 3.96875-1.125 1.125-2.44792 2.01563-3.96875 2.67188-1.52083 0.65625-3.14583 0.98438-4.875 0.98437l0 0"
