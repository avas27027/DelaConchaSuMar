  <nav class="nav">
    {
      navItems.map((item) => {
        let active = false;
        const currentPath = url.pathname.replace(/\/$/, "");
        if (`/${item.id}` === currentPath) {
          active = true;
        }
        return (
          <a href={`/${item.id}`} class={`nav-link ${active ? "active" : ""}`}>
            <div class="icon-container">
              <svg
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d={item.icon} fill="currentColor" />
              </svg>
            </div>
            <span class="nav-text">{item.name}</span>
          </a>
        );
      })
    }
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--spacing-sidebar);
    height: 100vh;
    background-color: var(--color-sidebar);
    padding: 24px 0;
    display: flex;
    flex-direction: column;
    border-right: 1px solid #bec8cd4d;
    position: sticky;
    top: 0;
  }

  .logo-container {
    padding: 0 24px;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 40px;
    height: 40px;
    background-color: var(--color-brand-cyan);
    border-radius: 8px;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .brand-info {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-deep-cyan);
    letter-spacing: -0.45px;
  }

  .terminal-info {
    font-size: 12px;
    font-weight: 500;
    color: rgb(var(--color-sea-cyan-rgb) / 36%);
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 8px;
    flex-grow: 1;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    transition: all 0.2s ease;
    color: rgb(var(--color-sea-cyan-rgb) / 49%);
  }

  .nav-link:hover {
    background-color: #0077911a;
    color: var(--color-brand-cyan);
  }

  .nav-link.active {
    background-color: var(--color-brand-cyan);
    color: var(--color-white);
  }

  .icon-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav-text {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
  }
</style>
