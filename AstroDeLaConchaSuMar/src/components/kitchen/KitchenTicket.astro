---
import ContadorReact from './Clock';

interface Props {
    orderNumber: string;
    customerName: string;
    urgency: 'high' | 'medium' | 'new' | 'in-progress';
    time: string;
    items: {
        quantity: number;
        name: string;
        note?: string;
    }[];
}

const { orderNumber, customerName, urgency, time, items } = Astro.props;

const urgencyColors = {
    'high': '#ba1a1a',
    'medium': '#973307',
    'new': '#007791',
    'in-progress': '#005d72'
};

const urgencyTags = {
    'high': 'Alta Prioridad',
    'medium': 'Pendiente',
    'new': 'Nuevo',
    'in-progress': 'En Proceso'
};

const urgencyTagBg = {
    'high': '#ffdad6',
    'medium': '#fff1e0',
    'new': '#b5ebff',
    'in-progress': '#dbe4ea'
};

const urgencyTagText = {
    'high': '#ba1a1a',
    'medium': '#973307',
    'new': '#007791',
    'in-progress': '#005d72'
};

const borderColor = urgencyColors[urgency];
---

<div class="kitchen-ticket" style={`border-left-color: ${borderColor}`}>
    <div class="ticket-header">
        <div class="header-left">
            <h2 class="order-number">Pedido #{orderNumber}</h2>
            <p class="customer-name">{customerName}</p>
        </div>
        <div class="header-right">
            <span class="urgency-tag" style={`background-color: ${urgencyTagBg[urgency]}; color: ${urgencyTagText[urgency]}`}>
                {urgencyTags[urgency]}
            </span>
            <ContadorReact horaInicialStr={time} client:load/>
        </div>
    </div>

    <div class="ticket-items">
        {items.map((item) => (
            <div class="ticket-item">
                <div class="item-quantity">{item.quantity}</div>
                <div class="item-details">
                    <p class="item-name">{item.name}</p>
                    {item.note && <p class="item-note">{item.note}</p>}
                </div>
            </div>
        ))}
    </div>

    <div class="ticket-footer">
        <button class="btn-ready">Marcar como Listo</button>
    </div>
</div>

<style>
    .kitchen-ticket {
        background-color: white;
        border-radius: 12px;
        box-shadow: 0 10px 26.25px #005d720a;
        display: flex;
        flex-direction: column;
        border-left: 8px solid transparent;
        overflow: hidden;
        height: fit-content;
    }

    .ticket-header {
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 1px solid #e7eff6;
    }

    .order-number {
        font-family: var(--font-heading);
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
        margin-bottom: 4px;
    }

    .customer-name {
        font-size: 14px;
        color: var(--color-text-secondary);
    }

    .header-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }

    .urgency-tag {
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    

    .ticket-items {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .ticket-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
    }

    .item-quantity {
        background-color: #b5ebff;
        color: #007791;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-weight: 700;
        font-size: 14px;
        flex-shrink: 0;
    }

    .item-name {
        font-size: 16px;
        font-weight: 500;
        color: var(--color-text-primary);
    }

    .item-note {
        font-size: 12px;
        color: var(--color-text-secondary);
        margin-top: 2px;
        font-style: italic;
    }

    .ticket-footer {
        padding: 16px;
        background-color: #edf5fc;
        display: flex;
        justify-content: center;
        gap: 8px;
    }

    .btn-pause {
        background-color: #dbe4ea;
        color: #005d72;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-family: var(--font-heading);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        flex: 1;
        transition: opacity 0.2s;
    }

    .btn-ready {
        background-color: #005d72;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-family: var(--font-heading);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        flex: 2;
        transition: opacity 0.2s;
        box-shadow: 0 4px 5.25px #0000001a;
    }

    .btn-pause:hover, .btn-ready:hover {
        opacity: 0.9;
    }
</style>
