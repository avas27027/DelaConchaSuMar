---
interface Props {
  image: string;
  price: string;
  title: string;
  description: string;
}

const { image, price, title, description } = Astro.props;
---

<div class="dish-card">
  <div class="image-container">
    <img src={image} alt={title} class="dish-image" />
    <div class="price-badge">
      <span>S/ {price}</span>
    </div>
  </div>
  
  <div class="dish-info">
    <h3 class="dish-title">{title}</h3>
    <p class="dish-description">{description}</p>
  </div>
</div>

<style>
  .dish-card {
    background-color: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #bec8cd4d;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
    cursor: pointer;
  }

  .dish-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .image-container {
    position: relative;
    height: 192px;
    width: 100%;
    overflow: hidden;
  }

  .dish-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .dish-card:hover .dish-image {
    transform: scale(1.05);
  }

  .price-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(3.5px);
    padding: 4px 12px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-deep-cyan);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .price-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(3.5px);
    padding: 4px 12px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-deep-cyan);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .dish-info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-grow: 1;
  }

  .dish-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin-bottom: 4px;
    white-space: pre-wrap;
  }

  .dish-description {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .tags-container {
    display: flex;
    gap: 8px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>
