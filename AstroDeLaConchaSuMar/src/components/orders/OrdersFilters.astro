---
---

<div class="filters-container">
  <div class="search-and-status">
    <div class="search-input-wrapper">
      <div class="search-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.1 19l-5.4-5.4c-0.6 0.4-1.3 0.7-2 0.9-0.7 0.2-1.5 0.3-2.3 0.3-2.1 0-3.8-0.7-5.2-2.1-1.4-1.4-2.1-3.1-2.1-5.2s0.7-3.8 2.1-5.2c1.4-1.4 3.1-2.1 5.2-2.1s3.8 0.7 5.2 2.1c1.4 1.4 2.1 3.1 2.1 5.2 0 0.8-0.1 1.6-0.3 2.3-0.2 0.7-0.5 1.4-0.9 2l5.4 5.4-1.2 1.2 0 0m-10.1-6c1.4 0 2.6-0.5 3.6-1.5 1-1 1.5-2.2 1.5-3.6s-0.5-2.6-1.5-3.6c-1-1-2.2-1.5-3.6-1.5s-2.6 0.5-3.6 1.5c-1 1-1.5 2.2-1.5 3.6s0.5 2.6 1.5 3.6c1 1 2.2 1.5 3.6 1.5l0 0" fill="#3f484c" />
        </svg>
      </div>
      <input type="text" placeholder="Buscar por ID u orden..." class="search-input" />
    </div>
    
    <div class="status-filters">
      <button class="status-btn active">Todas</button>
      <button class="status-btn">Pendientes</button>
      <button class="status-btn">Recibidas</button>
      <button class="status-btn">Canceladas</button>
    </div>
  </div>

  <div class="secondary-filters">
    <button class="date-picker-btn">
      <div class="icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 20c-0.83333 0-1.54167-0.29167-2.125-0.875C1.29167 18.5417 1 17.8333 1 17l0-12c0-0.83333 0.29167-1.54167 0.875-2.125C2.45833 2.29167 3.16667 2 4 2l1 0 0-2 2 0 0 2 6 0 0-2 2 0 0 2 1 0c0.83333 0 1.54167 0.29167 2.125 0.875C18.7083 3.45833 19 4.16667 19 5l0 12c0 0.83333-0.29167 1.54167-0.875 2.125C17.5417 19.7083 16.8333 20 16 20l-12 0 0 0m0-2l12 0 0-10-12 0 0 10 0 0m0-12l12 0 0-1 0 0-12 0 0 1 0 0m3 9l2 0 0-2-2 0 0 2 0 0m4 0l2 0 0-2-2 0 0 2 0 0m4 0l2 0 0-2-2 0 0 2 0 0m-8 4l2 0 0-2-2 0 0 2 0 0m4 0l2 0 0-2-2 0 0 2 0 0m4 0l2 0 0-2-2 0 0 2 0 0" fill="#151d22" />
        </svg>
      </div>
      <span>Últimos 30 días</span>
      <div class="chevron">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 9L1 4l1-1 4 4 4-4 1 1-5 5 0 0" fill="#151d22" />
        </svg>
      </div>
    </button>
    
    <button class="icon-btn">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 15l0-2 6 0 0 2-6 0 0 0m-4-4l0-2 14 0 0 2-14 0 0 0m-2-4l0-2 18 0 0 2-18 0 0 0" fill="#151d22" />
      </svg>
    </button>
  </div>
</div>

<style>
  .filters-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .search-and-status {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .search-input-wrapper {
    position: relative;
    width: 320px;
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background-color: #edf5fc;
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 12px 16px 12px 40px;
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    color: #151d22;
    outline: none;
    transition: all 0.2s ease;
  }

  .search-input:focus {
    background-color: white;
    border-color: var(--color-sea-cyan);
    box-shadow: 0 0 0 4px rgb(var(--color-sea-cyan-rgb) / 10%);
  }

  .status-filters {
    display: flex;
    background-color: #edf5fc;
    padding: 6px;
    border-radius: 12px;
    gap: 8px;
  }

  .status-btn {
    padding: 6px 12px;
    border: none;
    background: transparent;
    border-radius: 8px;
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #3f484c;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .status-btn.active {
    background-color: var(--color-sea-cyan);
    color: white;
  }

  .secondary-filters {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .date-picker-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: white;
    border: 1px solid rgba(190, 200, 205, 0.2);
    padding: 12px 16px;
    border-radius: 12px;
    font-family: 'Manrope', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #151d22;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .date-picker-btn:hover {
    background-color: #f8fbff;
    border-color: rgba(190, 200, 205, 0.4);
  }

  .icon-btn {
    width: 44px;
    height: 44px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: white;
    border: 1px solid rgba(190, 200, 205, 0.2);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .icon-btn:hover {
    background-color: #f8fbff;
    border-color: rgba(190, 200, 205, 0.4);
  }

  .chevron {
    display: flex;
    align-items: center;
  }
</style>
