<Layout title="De la Concha su Mar">
  <section class="menu-management-page" aria-labelledby="menu-title">
    <div class="menu-header">
      <div>
        <h2 id="menu-title">GESTIÓN DE MENÚ</h2>
        <p>Administra la disponibilidad y detalles de la carta maestra.</p>
      </div>

      <a
        class="add-dish-button"
        href="/menu/nuevo"
        aria-label="Agregar platillo"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M12 5v14M5 12h14"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
        Agregar Platillo
      </a>
    </div>
  </section>
  <MenuTable client:only="react" />
</Layout>

<style>
  .menu-management-page {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .menu-header h2 {
    color: var(--color-deep-cyan);
    font-size: 32px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0;
  }

  .menu-header p {
    color: var(--color-text-secondary);
    font-size: 13px;
    font-weight: 500;
  }

  .add-dish-button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 8px;
    background: var(--color-brand-cyan);
    color: var(--color-white);
    padding: 0 18px;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 8px 14px rgb(var(--color-sea-cyan-rgb) / 12%);
  }
</style>
