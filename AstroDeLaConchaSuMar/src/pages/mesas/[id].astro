---
import Layout from "../../layouts/Layout.astro";
import MenuDetalle from "../../components/menu/MenuDetalle";
import type { DishCardProps } from "../../components/menu/DishCard";

const { id } = Astro.params;

type RestMenuInterface = {
  id: string;
  name: string;
  imageUrl: string;
  description: string;
  price: number;
  priceMeassure: any;
};

const orders = [
  { name: "Ceviche Clásico", price: 45, quantity: 1 },
  { name: "Causa Limeña", price: 60, quantity: 2 },
];

const res = await fetch(
  `${process.env.BACKEND_URL ?? "http://localhost:3001"}/menu`,
  {
    method: "GET",
  },
)
  .then((res) => res.json())
  .catch((error) => {
    console.error("Error fetching menu:", error);
    return { data: [] };
  });
const dishes1: DishCardProps[] =
  res.data?.map(
    ({ id, name, imageUrl, description, price }: RestMenuInterface) => {
      return { id, image: imageUrl, price, title: name, description };
    },
  ) || [];
---

<Layout title={`Mesa - De la Concha su Mar`}>
  <MenuDetalle client:only="react" mesaName={`${id}`} initialDishes={dishes1} />
</Layout>
