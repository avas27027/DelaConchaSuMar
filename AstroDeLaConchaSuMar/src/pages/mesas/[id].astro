---
import Layout from "../../layouts/Layout.astro";
import MenuDetalle from "../../components/mesasOrder/MenuDetalle";
import type { DishCardProps } from "../../components/mesasOrder/DishCard";
const backendUrl = import.meta.env.BACKEND_URL ?? "http://backend:3001";
const { id } = Astro.params;

type RestMenuInterface = {
  id: string;
  name: string;
  imageUrl: string;
  description: string;
  price: number;
  priceMeassure: any;
};

const orders = [
  { name: "Ceviche Clásico", price: 45, quantity: 1 },
  { name: "Causa Limeña", price: 60, quantity: 2 },
];

console.log(backendUrl);
const res = await fetch(
  `${backendUrl}/menu`,
  {
    method: "GET",
  },
)
  .then((res) => res.json())
  .catch((error) => {
    console.error("Error fetching menu:", error);
    return { data: [] };
  });
const dishes1: DishCardProps[] =
  res.data?.map(
    ({ id, name, imageUrl, description, price }: RestMenuInterface) => {
      return { id, image: imageUrl, price, title: name, description };
    },
  ) || [];
---

<Layout title={`Mesa - De la Concha su Mar`}>
  <MenuDetalle client:only="react" mesaName={`${id}`} initialDishes={dishes1} />
</Layout>
